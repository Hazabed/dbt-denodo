# Copy to test.env and fill in to run the functional test suite against a
# live Denodo Virtual DataPort server.
DENODO_TEST_HOST=localhost
DENODO_TEST_PORT=9996
DENODO_TEST_USER=admin
DENODO_TEST_PASSWORD=admin
# Virtual database the tests build into. The test user needs privileges to
# create/drop databases (functional tests create one schema per test), or
# pre-create it and adjust the suite.
DENODO_TEST_DATABASE=dbt_test
